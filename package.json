{
  "name": "zen-study-stats",
  "version": "0.7.1",
  "private": true,
  "description": "ZEN Study の自分の学習データを見やすく可視化する個人用ブラウザ拡張（表示専用・read-only / GETのみ）",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/sync-version.mjs && tsc --noEmit && vite build && node scripts/build-popup.mjs && node scripts/build-demo.mjs",
    "build:demo": "node scripts/build-demo.mjs",
    "package": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/package.ps1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"dev/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"dev/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.0.270",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.6",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.65.0",
    "vite": "^5.4.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "uplot": "^1.6.31"
  }
}
