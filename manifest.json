{
  "manifest_version": 3,
  "name": "学習統計 for ZEN Study",
  "version": "0.7.1",
  "description": "自分の学習データを見やすく可視化する表示専用ツール（非公式）。read-only / GETのみ。学習記録は一切変更しません。",
  "homepage_url": "https://github.com/mug1ch4/zen-study-stats",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ZEN Study 学習統計",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.nnn.ed.nico/*",
    "https://www.nnn.ed.nico/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.nnn.ed.nico/*"],
      "js": ["observer.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://www.nnn.ed.nico/*"],
      "js": ["dist/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
